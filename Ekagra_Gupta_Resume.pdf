<!doctype html>
<html lang="en">
  <head>
    <script type="module">import { injectIntoGlobalHook } from "/@react-refresh";
injectIntoGlobalHook(window);
window.$RefreshReg$ = () => {};
window.$RefreshSig$ = () => (type) => type;</script>

    <script type="module" src="/@vite/client"></script>

    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>Ekagra Gupta — Developer | AI Engineer | Security Researcher</title>
    <meta name="description" content="Portfolio of Ekagra Gupta — Full-Stack Developer, AI/ML Engineer, and Cybersecurity Enthusiast. B.Tech CSE student at VIT Bhopal. Building intelligent systems at the intersection of AI and security." />
    <meta name="author" content="Ekagra Gupta" />
    <meta name="keywords" content="Ekagra Gupta, portfolio, developer, AI engineer, cybersecurity, VIT Bhopal, full-stack, Python, React, machine learning" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ekagrazi.com/" />
    <meta property="og:title" content="Ekagra Gupta — Developer | AI Engineer | Security Researcher" />
    <meta property="og:description" content="Building intelligent systems at the intersection of AI and security." />
    <meta property="og:site_name" content="Ekagra Gupta Portfolio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Ekagra Gupta — Developer | AI Engineer" />
    <meta name="twitter:description" content="Building intelligent systems at the intersection of AI and security." />

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Prevent FOUC — set background immediately -->
    <style>
      html, body { background: #0a0a0a; }
    </style>

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Canonical -->
    <link rel="canonical" href="https://ekagrazi.com/" />
  </head>
  <body>
    <div id="root"></div>
